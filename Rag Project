    st.markdown(f"<h2 style='color:{color}'>{score}%</h2>", unsafe_allow_html=True)
    st.progress(min(int(score), 100))

    # ── RAG: retrieved context ────────────────
    context = resume_text[:1500]  # top ~1500 chars as retrieved chunk

    with st.expander("📄 Retrieved Resume Context (RAG chunk)", expanded=False):
        st.text(context[:600] + ("…" if len(context) > 600 else ""))

    # ── LLM: Cohere analysis ──────────────────
    st.subheader("🤖 AI Analysis")
    with st.spinner("Asking Cohere to analyse the candidate…"):
