# ─────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────
def extract_text_from_pdf(file) -> str:
    """Extract all text from an uploaded PDF file."""
    reader = PdfReader(file)
    text = ""
    for page in reader.pages:
        page_text = page.extract_text()
        if page_text:
            text += page_text + "\n"
    return text.strip()


def compute_similarity(text_a: str, text_b: str) -> float:
    """Return TF-IDF cosine similarity (0–100) between two texts."""
    vectorizer = TfidfVectorizer(stop_words="english")
    vectors = vectorizer.fit_transform([text_a, text_b])
    score = cosine_similarity(vectors[0:1], vectors[1:2])[0][0]
    return round(score * 100, 2)


def analyse_with_cohere(api_key: str, job_desc: str, resume_context: str) -> str:
    """Call Cohere chat API and return the analysis text."""
    # Cohere SDK v5+ uses ClientV2 with the messages-style chat API
    co = cohere.ClientV2(api_key=api_key)

    prompt = f"""You are an expert AI hiring assistant.

Job Description:
{job_desc}

Candidate Resume (excerpt):
{resume_context}

Please analyse the candidate and provide a structured report covering:
1. **Match Evaluation** — how well does the candidate align with the role?
2. **Key Strengths** — what does the candidate bring that fits well?
3. **Missing Skills / Gaps** — what important requirements are absent?
4. **Final Recommendation** — hire / consider / pass, and why.

Be concise, specific, and professional.
"""

    response = co.chat(
        model="command-r-08-2024",           # use command-r or command-r-plus
        messages=[
            {"role": "user", "content": prompt}
        ],
    )

    # Cohere v5 response structure: response.message.content[0].text
    return response.message.content[0].text


